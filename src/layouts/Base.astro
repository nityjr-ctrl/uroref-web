---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "UroRef — evidence for UK urology trainees. A weekly publication on landmark trials, on-call pathways and FRCS-standard summaries, paired with the UroRef app.",
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImage = new URL(image, Astro.site ?? Astro.url);

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'UroRef',
  url: (Astro.site ?? Astro.url).toString().replace(/\/$/, ''),
  logo: new URL('/icon-512.png', Astro.site ?? Astro.url).toString(),
  description,
  sameAs: ['https://github.com/nityjr-ctrl/uroref-app'],
};

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'UroRef',
  url: (Astro.site ?? Astro.url).toString().replace(/\/$/, ''),
  description,
};
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | UroRef</title>
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0A2540" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="UroRef" />
  <meta property="og:title" content={`${title} | UroRef`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | UroRef`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Nav -->
  <header class="site-nav">
    <div class="site-nav-inner">
      <a href="/" class="u-wordmark" style="font-size: 22px;" aria-label="UroRef home">
        <span class="uro">Uro</span><span class="ref">Ref</span>
        <span class="dot" style="width: 4px; height: 4px; margin-bottom: 1px;"></span>
      </a>

      <nav class="site-nav-links">
        <a href="/deep-dives">Blog</a>
        <a href="/deep-dives">Landmark Trials</a>
        <a href="/deep-dives">FRCS</a>
        <a href="/about">About</a>
        <a href="/app">App</a>
      </nav>

      <a href="https://forms.gle/4QTK3MSgMsedJQEw7" target="_blank" rel="noopener" class="site-nav-cta">Subscribe</a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="site-footer-inner">
      <div class="site-footer-top">
        <div class="about">
          <span class="u-wordmark" style="font-size: 22px;">
            <span class="uro">Uro</span><span class="ref">Ref</span>
            <span class="dot" style="width: 4px; height: 4px; margin-bottom: 1px;"></span>
          </span>
          <p>A weekly urology training publication. Written by Nity G, Urology SpR, North West Deanery.</p>
        </div>
        <div>
          <h4>Read</h4>
          <ul>
            <li><a href="/deep-dives">Latest</a></li>
            <li><a href="/deep-dives">Landmark Trials</a></li>
            <li><a href="/deep-dives">On-Call</a></li>
            <li><a href="/deep-dives">FRCS Revision</a></li>
            <li><a href="/last30days">Trending</a></li>
          </ul>
        </div>
        <div>
          <h4>Product</h4>
          <ul>
            <li><a href="/app">iOS app</a></li>
            <li><a href="/app">Android app</a></li>
            <li><a href="/updates">Changelog</a></li>
            <li><a href="https://github.com/nityjr-ctrl/uroref-app" target="_blank" rel="noopener">GitHub</a></li>
          </ul>
        </div>
        <div>
          <h4>About</h4>
          <ul>
            <li><a href="/about">The author</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/privacy">Privacy</a></li>
            <li><a href="/terms">Terms</a></li>
          </ul>
        </div>
      </div>

      <div class="site-footer-disclaimer">
        <b>Medical disclaimer.</b> UroRef is an educational resource for healthcare professionals. It does not constitute medical advice. Always follow local guidelines and clinical judgement.
      </div>

      <div class="site-footer-legal">
        <span>© 2026 UroRef · Nity G, Urology SpR</span>
        <div>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  /* ══════════ Shared site nav + footer (v1) ══════════ */
  .site-nav {
    background: rgba(10, 37, 64, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 20px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .site-nav-links {
    display: flex;
    gap: 28px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .site-nav-links a { transition: color 0.15s; }
  .site-nav-links a:hover, .site-nav-links a.on { color: var(--text-primary); }
  .site-nav-cta {
    font-size: 13px;
    font-weight: 600;
    padding: 8px 14px;
    background: var(--teal-500);
    color: var(--navy-900);
    border-radius: var(--r-full);
    letter-spacing: -0.005em;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .site-nav-cta:hover { background: var(--teal-400); }

  @media (max-width: 820px) {
    .site-nav-inner { padding: 16px 20px; gap: 16px; }
    .site-nav-links { display: none; }
  }

  .site-footer {
    padding: 64px 32px 40px;
    color: var(--text-muted);
    font-size: 13px;
    border-top: 1px solid var(--border);
    margin-top: 96px;
  }
  .site-footer-inner { max-width: var(--container); margin: 0 auto; }
  .site-footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .site-footer-top h4 {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin: 0 0 14px 0;
  }
  .site-footer-top ul { list-style: none; padding: 0; margin: 0; }
  .site-footer-top li { margin-bottom: 8px; }
  .site-footer-top li a { color: var(--text-secondary); font-size: 14px; transition: color 0.15s; }
  .site-footer-top li a:hover { color: var(--text-primary); }
  .site-footer-top .about p {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 34ch;
    margin: 12px 0 0 0;
  }
  .site-footer-disclaimer {
    padding: 20px 24px;
    background: var(--navy-900);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .site-footer-disclaimer b { color: var(--text-secondary); font-weight: 500; }
  .site-footer-legal {
    display: flex;
    justify-content: space-between;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 11px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .site-footer-legal a { margin-left: 20px; transition: color 0.15s; }
  .site-footer-legal a:hover { color: var(--text-primary); }

  @media (max-width: 820px) {
    .site-footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
    .site-footer-top .about { grid-column: 1 / -1; }
    .site-footer-legal a { margin-left: 14px; }
    .site-footer { padding: 48px 20px 32px; }
  }
</style>
