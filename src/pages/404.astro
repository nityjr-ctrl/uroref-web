---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="That page doesn't exist on UroRef.">

  <section class="u-hero" style="padding: 8rem 1.5rem; text-align: center; min-height: 70vh; display: flex; align-items: center; justify-content: center;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>

    <div style="max-width: 600px; margin: 0 auto; position: relative;">
      <div style="font-family: 'JetBrains Mono', monospace; font-size: clamp(5rem, 18vw, 9rem); font-weight: 800; line-height: 1; letter-spacing: -0.05em; margin-bottom: 0.75rem;" class="u-gradient-text">
        404
      </div>
      <h1 style="color: white; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin: 0 0 1rem; letter-spacing: -0.02em;">
        That protocol doesn't exist.
      </h1>
      <p style="color: rgba(255,255,255,0.65); font-size: 1rem; margin: 0 0 2.5rem; line-height: 1.65;">
        The page you're looking for has moved, been renamed, or never existed. Try one of these instead:
      </p>
      <div style="display: flex; gap: 0.875rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="u-cta-primary">← Back home</a>
        <a href="/last30days" class="u-cta-ghost">See what's trending</a>
      </div>
    </div>
  </section>

</Base>
