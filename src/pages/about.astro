---
import Base from '../layouts/Base.astro';

const contents = [
  ['🩺', 'Procedures', '16 common urology procedures with consent risks, operative steps, post-op orders, and ward round checklists.'],
  ['🚨', 'Emergencies', "On-call decision trees for haematuria, retention, scrotal pain, priapism, penile fracture, paraphimosis, catheter problems, loin pain and fever, and more."],
  ['💊', 'Drugs', 'Urology-specific drug doses, antibiotic protocols, renal adjustments, and drug interaction flags.'],
  ['🧮', 'Calculators', 'IDENTIFY (haematuria cancer risk), MIMIC (stone passage), TWIST (torsion), eGFR, CPG, prostate volume.'],
  ['🏥', 'Clinic', 'Outpatient presentation frameworks, investigation pathways, referral guidance.'],
  ['📄', 'BAUS Leaflets', '31 BAUS-approved patient information leaflets via QR code.'],
];

const thanks = [
  'Mr Yehia Abdallah',
  'Mr Grigorios Athanasiadis',
  'Mr Tom Farmer',
  'Mr Oladapo Feyisetan',
  'Mr Rob Mason',
  'Mr Chirag Patel',
  'Mr Omar Shareef',
];
---
<Base title="About UroRef" description="UroRef is a urology quick-reference tool, authored by Nity G (Urology SpR), used by 500+ trainees across the UK. Referenced to EAU 2024, NICE and BAUS.">

  <section class="u-hero" style="padding: 5.5rem 1.5rem 4.5rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <div class="u-eyebrow-pill" style="margin-bottom: 1.5rem;">About</div>
      <h1 class="u-gradient-text" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1.25rem; line-height: 1.15;">It started as a personal tool.</h1>
      <p style="color: rgba(255,255,255,0.75); font-size: 1.2rem; line-height: 1.65; margin: 0; max-width: 600px;">
        It is now used by <strong style="color:#33DDD3; font-weight: 700;">500+ trainees</strong> across the UK.
      </p>
    </div>
  </section>

  <section class="about-body">

    <!-- What's in the app -->
    <div class="about-block">
      <h2>What's in the app</h2>
      <div class="about-grid">
        {contents.map(([icon, title, desc]) => (
          <div class="about-card">
            <span class="icon">{icon}</span>
            <div>
              <p class="title">{title}</p>
              <p class="desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Governance -->
    <div class="about-governance">
      <h2>Governance</h2>
      <p>UroRef is a quick reference tool. It is not a substitute for clinical judgement, senior advice, or local protocols.</p>
      <p>All content is referenced to <strong>EAU 2024 guidelines</strong>, <strong>NICE</strong>, and <strong>BAUS</strong>.</p>
      <p>Content is authored by Nity G, Urology SpR.</p>
      <p>See the <a href="/credits" style="color: var(--teal-500); font-weight: 600;">full credits and attributions</a> for clinical sources, calculator references, and the open-source software the app is built on.</p>
    </div>

    <!-- Thanks -->
    <div class="about-block">
      <h2>With thanks to</h2>
      <div class="about-thanks">
        <div class="thanks-grid">
          {thanks.map(name => (
            <div class="thanks-name">{name}</div>
          ))}
        </div>
        <p class="thanks-foot">And urology trainees across the North West Deanery.</p>
      </div>
    </div>

    <!-- Feedback -->
    <div class="about-feedback">
      <p>Questions or feedback?</p>
      <a href="https://forms.gle/4QTK3MSgMsedJQEw7" target="_blank" rel="noopener" class="u-cta-primary">Send feedback →</a>
    </div>

  </section>

  <style>
    .about-body {
      padding: 4rem 1.5rem;
      max-width: 750px;
      margin: 0 auto;
    }
    .about-block { margin-bottom: 3.25rem; }
    .about-body h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0 0 1.25rem;
      letter-spacing: -0.01em;
    }
    .about-grid { display: grid; gap: 0.75rem; }
    .about-card {
      display: flex;
      gap: 1rem;
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.25rem;
      align-items: flex-start;
      transition: border-color 0.15s;
    }
    .about-card:hover { border-color: var(--border-strong); }
    .about-card .icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
    .about-card .title { font-weight: 600; color: var(--text-primary); margin: 0 0 0.25rem; font-size: 0.98rem; }
    .about-card .desc {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      margin: 0;
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .about-governance {
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.85rem;
      margin-bottom: 3rem;
    }
    .about-governance h2 { margin-bottom: 0.9rem; }
    .about-governance p {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      margin: 0 0 0.9rem;
      font-size: 0.95rem;
      line-height: 1.7;
    }
    .about-governance p:last-child { margin: 0; }
    .about-governance strong { color: var(--text-primary); font-weight: 600; }
    .about-thanks {
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.75rem;
    }
    .thanks-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 0.6rem 1.25rem;
      margin-bottom: 1rem;
    }
    .thanks-name { color: var(--text-secondary); font-size: 0.95rem; font-weight: 500; }
    .thanks-foot {
      font-family: var(--font-serif);
      color: var(--text-muted);
      margin: 0;
      font-size: 0.9rem;
      line-height: 1.65;
    }
    .about-feedback { text-align: center; }
    .about-feedback p {
      color: var(--text-muted);
      margin: 0 0 1rem;
      font-size: 0.95rem;
    }
  </style>

</Base>
