---
import Base from '../layouts/Base.astro';
---
<Base title="Download UroRef" description="Download UroRef — the urology quick reference app for trainees. Available on iOS and Android.">

  <!-- Hero -->
  <section class="u-hero" style="padding: 5.5rem 1.5rem 4.5rem; text-align: center;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <div class="u-eyebrow-pill" style="margin-bottom: 1.5rem;">Download</div>
      <h1 class="u-gradient-text" style="font-size: clamp(2rem, 5.5vw, 3.5rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem; line-height: 1.1;">
        Get UroRef on your phone.
      </h1>
      <p style="color: rgba(255,255,255,0.72); font-size: 1.15rem; margin: 0 auto 0.5rem; line-height: 1.6; max-width: 560px;">
        100+ urology protocols. Drug doses. On-call emergency guides. FRCS viva cards.
      </p>
      <p style="color: rgba(255,255,255,0.5); font-size: 0.9rem; margin: 0;">
        Free. Built for trainees. Available on iOS and Android.
      </p>
    </div>
  </section>

  <!-- Download badges -->
  <section style="padding: 4rem 1.5rem; max-width: 800px; margin: 0 auto; text-align: center;">
    <h2 style="font-size: 1.5rem; font-weight: 700; color: #0f2b46; margin: 0 0 0.75rem;">Get the app</h2>
    <p style="color: #64748b; margin: 0 0 2.5rem;">Choose your platform. Live download links coming soon.</p>

    <div class="badge-row">
      <!-- iOS App Store Badge -->
      <a href="#" class="store-badge" aria-label="Download on the App Store">
        <svg width="22" height="26" viewBox="0 0 384 512" aria-hidden="true">
          <path fill="currentColor" d="M318.7 268.7c-.3-36.7 16.4-64.4 50.3-84.8-19-27.1-47.6-42-85.4-44.9-35.7-2.8-74.7 21-89 21-15.1 0-49.6-20-76.7-20C72.8 141.6 16 184.5 16 271.9c0 25.8 4.7 52.4 14.1 79.7 12.6 36.1 58.1 124.7 105.5 123.2 24.8-.6 42.4-17.6 74.7-17.6 31.4 0 47.6 17.6 75.3 17.6 47.8-.7 89-81.3 100.9-117.5-63.5-29.9-67.8-87.7-67.8-89.6zM256.6 113.3c30.3-36 27.5-68.7 26.6-80.4-26.7 1.6-57.6 18.2-75.2 38.6-19.4 21.9-30.8 49-28.3 78.7 28.9 2.2 55.3-12.7 76.9-36.9z"/>
        </svg>
        <div class="store-text">
          <div class="store-eyebrow">Download on the</div>
          <div class="store-name">App Store</div>
        </div>
      </a>

      <!-- Google Play Badge -->
      <a href="#" class="store-badge" aria-label="Get it on Google Play">
        <svg width="22" height="26" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#34a853" d="M3.609 1.814 13.792 12 3.609 22.186a1 1 0 0 1-.609-.92V2.734a1 1 0 0 1 .609-.92z" opacity="0"/>
          <path fill="#34a853" d="M3 2.734v18.532a1 1 0 0 0 .25.66L13.792 12 3.25 2.073A1 1 0 0 0 3 2.734z"/>
          <path fill="#fbbc04" d="M16.81 8.99 6.05 2.79l9.235 9.21z"/>
          <path fill="#ea4335" d="M6.05 21.21 16.81 15.01 15.285 12z"/>
          <path fill="#4285f4" d="m20.16 10.81-3.35-1.82L13.792 12l3.018 3.01 3.35-1.82a1.36 1.36 0 0 0 0-2.38z"/>
        </svg>
        <div class="store-text">
          <div class="store-eyebrow">Get it on</div>
          <div class="store-name">Google Play</div>
        </div>
      </a>
    </div>

    <style>
      .badge-row {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 3rem;
      }
      .store-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        background: linear-gradient(135deg, #0f2b46 0%, #1e3a5f 100%);
        color: white;
        padding: 0.85rem 1.6rem;
        border-radius: 12px;
        text-decoration: none;
        min-width: 200px;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 8px 24px -12px rgba(15,43,70,0.4);
        transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      }
      .store-badge:hover {
        transform: translateY(-2px);
        border-color: rgba(245,158,11,0.4);
        box-shadow: 0 14px 30px -12px rgba(15,43,70,0.55);
      }
      .store-text { text-align: left; line-height: 1.15; }
      .store-eyebrow {
        font-size: 0.65rem;
        opacity: 0.7;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.15rem;
      }
      .store-name {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
    </style>

    <!-- QR Code placeholder -->
    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 2.5rem; margin-bottom: 2rem; max-width: 400px; margin-left: auto; margin-right: auto;">
      <div style="width: 160px; height: 160px; background-color: #f1f5f9; border-radius: 8px; margin: 0 auto 1.25rem; display: flex; align-items: center; justify-content: center; border: 2px dashed #cbd5e1;">
        <span style="color: #94a3b8; font-size: 0.8rem; text-align: center; padding: 0.5rem;">QR code<br/>coming soon</span>
      </div>
      <p style="font-size: 0.9rem; font-weight: 600; color: #0f2b46; margin: 0 0 0.25rem;">Print and pin to your ward noticeboard</p>
      <p style="font-size: 0.8rem; color: #64748b; margin: 0;">Scan to download UroRef instantly on any device.</p>
    </div>
  </section>

  <!-- Preview mockups -->
  <section class="u-hero" style="padding: 5rem 1.5rem 6rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div style="max-width: 1000px; margin: 0 auto; text-align: center; position: relative;">
      <h2 style="color: white; font-size: clamp(1.75rem, 3.5vw, 2.25rem); font-weight: 800; margin: 0 0 0.75rem; letter-spacing: -0.025em;">See it in action</h2>
      <p style="color: rgba(255,255,255,0.55); margin: 0 0 3rem; font-size: 0.95rem;">Illustrative previews — real screenshots ahead of launch.</p>

      <div class="phones">
        <!-- Phone 1 — Home / search -->
        <div class="phone phone-left">
          <div class="phone-screen" style="background: linear-gradient(180deg, #f8fafc, #eef2f7);">
            <div class="phone-notch"></div>
            <div class="phone-header">
              <div class="phone-time">09:41</div>
              <div class="phone-icons">●●● ▮</div>
            </div>
            <div class="phone-body">
              <div class="phone-title">UroRef</div>
              <div class="phone-search">🔍 Search protocols, drugs…</div>
              <div class="phone-chip-row">
                <span class="phone-chip phone-chip-on">On-call</span>
                <span class="phone-chip">Drugs</span>
                <span class="phone-chip">Viva</span>
              </div>
              <div class="phone-card">
                <div class="phone-card-label">PINNED</div>
                <div class="phone-card-title">Acute retention</div>
                <div class="phone-card-meta">On-call · 4-step</div>
              </div>
              <div class="phone-card">
                <div class="phone-card-label">PINNED</div>
                <div class="phone-card-title">Tamsulosin dose</div>
                <div class="phone-card-meta">Drug · renal-adj.</div>
              </div>
              <div class="phone-card phone-card-amber">
                <div class="phone-card-label" style="color:#d97706;">EMERGENCY</div>
                <div class="phone-card-title">Urosepsis</div>
                <div class="phone-card-meta">Sepsis-6 pathway</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Phone 2 — Emergency protocol (centre) -->
        <div class="phone phone-center">
          <div class="phone-screen" style="background: linear-gradient(180deg, #0a1d33, #0f2b46);">
            <div class="phone-notch"></div>
            <div class="phone-header phone-header-dark">
              <div class="phone-time">09:41</div>
              <div class="phone-icons">●●● ▮</div>
            </div>
            <div class="phone-body">
              <div class="phone-pill">🚨 EMERGENCY</div>
              <div class="phone-title phone-title-light">Urosepsis</div>
              <div class="phone-sub">Fever + obstructed system</div>
              <div class="phone-step">
                <div class="phone-step-num">1</div>
                <div class="phone-step-body">
                  <div class="phone-step-title">Sepsis 6 — now</div>
                  <div class="phone-step-desc">O₂, bloods + cultures, lactate, IV Abx, IV fluids, urine output</div>
                </div>
              </div>
              <div class="phone-step">
                <div class="phone-step-num">2</div>
                <div class="phone-step-body">
                  <div class="phone-step-title">CT KUB urgently</div>
                  <div class="phone-step-desc">Confirm level + degree of obstruction</div>
                </div>
              </div>
              <div class="phone-step phone-step-hot">
                <div class="phone-step-num" style="background:#f59e0b;color:#0a1d33;">3</div>
                <div class="phone-step-body">
                  <div class="phone-step-title" style="color:#fcd34d;">Decompress within hours</div>
                  <div class="phone-step-desc" style="color:rgba(255,255,255,0.7);">Nephrostomy or retrograde JJ — call consultant</div>
                </div>
              </div>
            </div>
          </div>
          <div class="phone-glow" aria-hidden="true"></div>
        </div>

        <!-- Phone 3 — Drug dose -->
        <div class="phone phone-right">
          <div class="phone-screen" style="background: linear-gradient(180deg, #f8fafc, #eef2f7);">
            <div class="phone-notch"></div>
            <div class="phone-header">
              <div class="phone-time">09:41</div>
              <div class="phone-icons">●●● ▮</div>
            </div>
            <div class="phone-body">
              <div class="phone-breadcrumb">← Drug doses</div>
              <div class="phone-title">Gentamicin</div>
              <div class="phone-sub" style="color:#64748b;">Aminoglycoside · urosepsis cover</div>
              <div class="phone-dose">
                <div class="phone-dose-label">Usual dose</div>
                <div class="phone-dose-value">5 mg/kg</div>
                <div class="phone-dose-unit">IV, once daily</div>
              </div>
              <div class="phone-warn">
                ⚠ Adjust in CKD — use IBW if obese. Monitor levels from day 2.
              </div>
              <div class="phone-card">
                <div class="phone-card-label">RENAL ADJ.</div>
                <div class="phone-card-title">eGFR 30–60: 3 mg/kg OD</div>
              </div>
              <div class="phone-card">
                <div class="phone-card-label">RENAL ADJ.</div>
                <div class="phone-card-title">eGFR &lt;30: seek advice</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <style>
      .phones {
        display: grid;
        grid-template-columns: 1fr 1.15fr 1fr;
        gap: 1.25rem;
        align-items: end;
        max-width: 900px;
        margin: 0 auto;
      }
      @media (max-width: 720px) {
        .phones { grid-template-columns: 1fr; gap: 2rem; max-width: 280px; }
      }
      .phone {
        position: relative;
        aspect-ratio: 9 / 19;
        border-radius: 32px;
        background: linear-gradient(160deg, #1f2937, #0f172a);
        padding: 6px;
        box-shadow:
          0 40px 80px -30px rgba(0,0,0,0.55),
          0 0 0 1px rgba(255,255,255,0.08);
        transform-origin: center bottom;
      }
      .phone-left  { transform: rotate(-4deg) translateY(18px) scale(0.92); }
      .phone-right { transform: rotate( 4deg) translateY(18px) scale(0.92); }
      .phone-center { z-index: 2; }
      @media (max-width: 720px) {
        .phone-left, .phone-right { transform: none; }
      }
      .phone-screen {
        position: relative;
        border-radius: 26px;
        width: 100%;
        height: 100%;
        overflow: hidden;
        color: #0f2b46;
      }
      .phone-notch {
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        width: 44%;
        height: 18px;
        background: #0a0f1a;
        border-radius: 12px;
        z-index: 5;
      }
      .phone-header {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 1.2rem 0.2rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        color: #0f2b46;
        font-weight: 600;
      }
      .phone-header-dark { color: rgba(255,255,255,0.7); }
      .phone-body {
        padding: 1.2rem 0.85rem;
        text-align: left;
        font-size: 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .phone-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f2b46;
        letter-spacing: -0.02em;
        margin: 0.15rem 0 0.35rem;
      }
      .phone-title-light { color: white; }
      .phone-sub {
        font-size: 0.62rem;
        color: rgba(255,255,255,0.6);
        margin-bottom: 0.25rem;
      }
      .phone-search {
        font-size: 0.62rem;
        color: #94a3b8;
        padding: 0.55rem 0.7rem;
        background: white;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
      }
      .phone-chip-row { display: flex; gap: 0.3rem; margin-top: 0.3rem; }
      .phone-chip {
        font-size: 0.55rem;
        color: #64748b;
        background: white;
        border: 1px solid #e2e8f0;
        padding: 0.2rem 0.5rem;
        border-radius: 100px;
        font-weight: 600;
      }
      .phone-chip-on {
        background: #0f2b46;
        color: white;
        border-color: #0f2b46;
      }
      .phone-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.55rem 0.7rem;
        line-height: 1.3;
      }
      .phone-card-amber {
        background: linear-gradient(135deg, #fffbeb, white);
        border-color: rgba(245,158,11,0.3);
      }
      .phone-card-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.5rem;
        color: #94a3b8;
        letter-spacing: 0.08em;
        margin-bottom: 0.1rem;
      }
      .phone-card-title {
        font-size: 0.72rem;
        font-weight: 700;
        color: #0f2b46;
      }
      .phone-card-meta {
        font-size: 0.55rem;
        color: #94a3b8;
        margin-top: 0.1rem;
      }
      .phone-pill {
        display: inline-block;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.52rem;
        font-weight: 700;
        color: #fcd34d;
        background: rgba(245,158,11,0.15);
        border: 1px solid rgba(245,158,11,0.3);
        padding: 0.15rem 0.5rem;
        border-radius: 100px;
        letter-spacing: 0.1em;
        align-self: flex-start;
      }
      .phone-step {
        display: flex;
        gap: 0.5rem;
        align-items: flex-start;
        padding: 0.55rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
      }
      .phone-step-hot {
        border-color: rgba(245,158,11,0.3);
        background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(255,255,255,0.03));
      }
      .phone-step-num {
        width: 18px; height: 18px;
        background: rgba(255,255,255,0.12);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.6rem;
        font-weight: 700;
        flex-shrink: 0;
      }
      .phone-step-title {
        font-size: 0.65rem;
        font-weight: 700;
        color: white;
        margin-bottom: 0.1rem;
      }
      .phone-step-desc {
        font-size: 0.55rem;
        color: rgba(255,255,255,0.55);
        line-height: 1.45;
      }
      .phone-breadcrumb {
        font-size: 0.6rem;
        color: #64748b;
        margin-bottom: 0.2rem;
      }
      .phone-dose {
        background: linear-gradient(135deg, #0f2b46, #1e3a5f);
        color: white;
        padding: 0.75rem;
        border-radius: 12px;
        margin: 0.35rem 0 0.25rem;
      }
      .phone-dose-label {
        font-size: 0.5rem;
        color: rgba(255,255,255,0.55);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .phone-dose-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #fcd34d;
        margin: 0.1rem 0;
      }
      .phone-dose-unit {
        font-size: 0.6rem;
        color: rgba(255,255,255,0.6);
      }
      .phone-warn {
        font-size: 0.58rem;
        color: #92400e;
        background: rgba(245,158,11,0.12);
        border: 1px solid rgba(245,158,11,0.25);
        padding: 0.4rem 0.55rem;
        border-radius: 8px;
        line-height: 1.4;
      }
      .phone-glow {
        position: absolute;
        inset: -20%;
        background: radial-gradient(circle at center, rgba(245,158,11,0.35), transparent 60%);
        filter: blur(40px);
        z-index: -1;
      }
    </style>
  </section>

  <!-- Features reminder -->
  <section style="padding: 4rem 1.5rem; max-width: 700px; margin: 0 auto;">
    <h2 style="font-size: 1.5rem; font-weight: 700; color: #0f2b46; margin: 0 0 1.5rem; text-align: center;">What's inside</h2>
    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.875rem;">
      {[
        '100+ urology protocols — catheterisation, stents, TURBT post-op, TRUS biopsy, cystoscopy',
        'On-call emergency guides — acute retention, urosepsis, frank haematuria, renal colic',
        'Drug doses with renal adjustment prompts (morphine, tamsulosin, gentamicin, ciprofloxacin)',
        'Procedure step-by-step guides built for registrar-level decision-making',
        'FRCS viva cards — structured high-yield answers for urology exit exams',
        'Pinned tools and recently used — fast access during busy shifts',
      ].map(item => (
        <li style="display: flex; gap: 0.75rem; align-items: flex-start;">
          <span style="color: #f59e0b; font-size: 1.1rem; margin-top: 0.1rem; flex-shrink: 0;">✓</span>
          <span style="color: #374151; font-size: 0.95rem; line-height: 1.6;">{item}</span>
        </li>
      ))}
    </ul>
  </section>

</Base>
