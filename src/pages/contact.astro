---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" description="Get in touch with UroRef — feedback, clinical corrections, or partnership enquiries.">

  <section class="u-hero" style="padding: 5.5rem 1.5rem 4.5rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <div class="u-eyebrow-pill" style="margin-bottom: 1.5rem;">Get in touch</div>
      <h1 class="u-gradient-text" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem;">Contact</h1>
      <p style="color: rgba(255,255,255,0.72); font-size: 1.1rem; line-height: 1.7; margin: 0;">
        Feedback, clinical corrections, or partnership enquiries — all welcome.
      </p>
    </div>
  </section>

  <section class="contact-body">

    <!-- Primary CTA -->
    <div class="contact-primary">
      <a href="mailto:nity@uroref.com" class="u-cta-primary">Email nity@uroref.com →</a>
      <p class="contact-link">Or use the <a href="https://forms.gle/4QTK3MSgMsedJQEw7" target="_blank" rel="noopener">30-second feedback form</a>.</p>
    </div>

    <!-- Clinical correction -->
    <div class="contact-card contact-card-accent">
      <div class="inner">
        <span class="icon">🩺</span>
        <div>
          <p class="title">Found a clinical error?</p>
          <p class="desc">Flag it via the feedback form and it will be reviewed and corrected within <strong>48 hours</strong>.</p>
        </div>
      </div>
    </div>

    <!-- Consultant review -->
    <div class="contact-card">
      <div class="inner">
        <span class="icon">👨‍⚕️</span>
        <div>
          <p class="title">Reviewing content for your subspecialty?</p>
          <p class="desc">We are building a consultant review layer and welcome involvement from consultants across all urology subspecialties.</p>
        </div>
      </div>
    </div>


  </section>

  <style>
    .contact-body { padding: 4rem 1.5rem; max-width: 700px; margin: 0 auto; }
    .contact-primary { text-align: center; margin-bottom: 2.5rem; }
    .contact-link {
      color: var(--text-muted);
      font-family: var(--font-mono);
      font-size: 0.8rem;
      margin: 1rem 0 0;
    }
    .contact-link a { color: var(--teal-500); transition: color 0.15s; }
    .contact-link a:hover { color: var(--teal-400); }
    .contact-card {
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.75rem;
      margin-bottom: 1.25rem;
      transition: border-color 0.15s;
    }
    .contact-card-accent {
      border-color: rgba(0,212,200,0.3);
      background:
        radial-gradient(circle at 0% 0%, rgba(0,212,200,0.08) 0%, transparent 50%),
        var(--navy-700);
    }
    .contact-card-link { display: block; text-decoration: none; }
    .contact-card-link:hover { border-color: var(--teal-500); }
    .contact-card .inner { display: flex; gap: 1.1rem; align-items: flex-start; }
    .contact-card .icon { font-size: 1.6rem; flex-shrink: 0; margin-top: 0.1rem; }
    .contact-card .title { font-weight: 600; color: var(--text-primary); margin: 0 0 0.4rem; font-size: 1rem; }
    .contact-card .desc {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.6;
    }
    .contact-card .desc strong { color: var(--text-primary); font-weight: 600; }
    .contact-card .url {
      color: var(--teal-500);
      margin: 0.5rem 0 0;
      font-size: 0.82rem;
      font-weight: 600;
      font-family: var(--font-mono);
    }
  </style>

</Base>
