---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" description="Get in touch with UroRef — feedback, clinical corrections, or partnership enquiries.">

  <section class="u-hero" style="padding: 5.5rem 1.5rem 4.5rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <div class="u-eyebrow-pill" style="margin-bottom: 1.5rem;">Get in touch</div>
      <h1 class="u-gradient-text" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem;">Contact</h1>
      <p style="color: rgba(255,255,255,0.72); font-size: 1.1rem; line-height: 1.7; margin: 0;">
        Feedback, clinical corrections, or partnership enquiries — all welcome.
      </p>
    </div>
  </section>

  <section style="padding: 4rem 1.5rem; max-width: 700px; margin: 0 auto;">

    <!-- Primary CTA -->
    <div style="text-align: center; margin-bottom: 2.5rem;">
      <a href="https://forms.gle/4QTK3MSgMsedJQEw7" target="_blank" rel="noopener" class="u-cta-primary">Send feedback — 30 second form →</a>
      <p style="color: #94a3b8; font-size: 0.85rem; margin: 1rem 0 0;">forms.gle/4QTK3MSgMsedJQEw7</p>
    </div>

    <!-- Clinical correction -->
    <div style="background: linear-gradient(135deg, #fffbeb, white); border: 1px solid rgba(0,212,200,0.3); border-radius: 12px; padding: 1.75rem; margin-bottom: 1.25rem;">
      <div style="display: flex; gap: 1.1rem; align-items: flex-start;">
        <span style="font-size: 1.6rem; flex-shrink: 0; margin-top: 0.1rem;">🩺</span>
        <div>
          <p style="font-weight: 700; color: #0A2540; margin: 0 0 0.4rem; font-size: 1rem;">Found a clinical error?</p>
          <p style="color: #374151; margin: 0; font-size: 0.95rem; line-height: 1.6;">
            Flag it via the feedback form and it will be reviewed and corrected within <strong style="color:#0A2540;">48 hours</strong>.
          </p>
        </div>
      </div>
    </div>

    <!-- Consultant review -->
    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.75rem; margin-bottom: 1.25rem;">
      <div style="display: flex; gap: 1.1rem; align-items: flex-start;">
        <span style="font-size: 1.6rem; flex-shrink: 0; margin-top: 0.1rem;">👨‍⚕️</span>
        <div>
          <p style="font-weight: 700; color: #0A2540; margin: 0 0 0.4rem; font-size: 1rem;">Reviewing content for your subspecialty?</p>
          <p style="color: #374151; margin: 0; font-size: 0.95rem; line-height: 1.6;">
            We are building a consultant review layer and welcome involvement from consultants across all urology subspecialties.
          </p>
        </div>
      </div>
    </div>

    <!-- GitHub -->
    <a href="https://github.com/nityjr-ctrl/uroref-app" target="_blank" rel="noopener" style="display: flex; gap: 1.1rem; background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.75rem; text-decoration: none; align-items: flex-start; transition: border-color 0.15s;" onmouseover="this.style.borderColor='#00D4C8'" onmouseout="this.style.borderColor='#e2e8f0'">
      <span style="font-size: 1.6rem; flex-shrink: 0; margin-top: 0.1rem;">⚙️</span>
      <div>
        <p style="font-weight: 700; color: #0A2540; margin: 0 0 0.4rem; font-size: 1rem;">GitHub</p>
        <p style="color: #374151; margin: 0 0 0.5rem; font-size: 0.95rem; line-height: 1.6;">View the UroRef app repository. Issues and PRs welcome for technical contributions.</p>
        <p style="color: #00D4C8; margin: 0; font-size: 0.82rem; font-weight: 600; font-family: 'JetBrains Mono', monospace;">github.com/nityjr-ctrl/uroref-app →</p>
      </div>
    </a>

  </section>

</Base>
