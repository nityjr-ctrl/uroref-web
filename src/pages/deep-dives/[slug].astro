---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('deep-dives');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---
<Base title={article.data.title} description={article.data.description} image="/og-image.png">

  <section class="u-hero" style="padding: 4.5rem 1.5rem 3.25rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <a href="/deep-dives" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1.5rem;" onmouseover="this.style.color='rgba(255,255,255,0.85)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">
        ← Deep Dives
      </a>
      <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
        {article.data.tags && article.data.tags.map((tag: string) => (
          <span style="background-color: rgba(0,212,200,0.15); color: #33DDD3; font-size: 0.72rem; padding: 0.25rem 0.65rem; border-radius: 100px; font-weight: 600; letter-spacing: 0.03em; border: 1px solid rgba(0,212,200,0.25);">{tag}</span>
        ))}
      </div>
      <h1 class="u-gradient-text" style="font-size: clamp(1.85rem, 4.5vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem; line-height: 1.2;">{article.data.title}</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.9rem; margin: 0 0 0.6rem;">{article.data.date} · Written by {article.data.author || 'Nity G, Urology SpR'}</p>
      <p class="article-safety-note">For reference only — not a substitute for clinical judgement.</p>
    </div>
  </section>

  <!-- Article body -->
  <article class="article-wrap">
    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .article-safety-note {
      color: rgba(255,255,255,0.38);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.02em;
      margin: 0;
    }
    .article-wrap {
      padding: 3.5rem 1.5rem 5rem;
      max-width: 720px;
      margin: 0 auto;
    }
    .prose h2 {
      font-size: 1.45rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 3rem 0 1.25rem;
      letter-spacing: -0.02em;
    }
    .prose h3 {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 2rem 0 0.75rem;
      letter-spacing: -0.015em;
    }
    .prose p {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      line-height: 1.8;
      margin: 0 0 1.25rem;
      font-size: 1.02rem;
    }
    .prose ul, .prose ol {
      color: var(--text-secondary);
      padding-left: 1.5rem;
      margin: 0.75rem 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .prose li {
      font-family: var(--font-serif);
      font-size: 0.98rem;
      line-height: 1.65;
    }
    .prose strong {
      color: var(--text-primary);
      font-weight: 600;
    }
    .prose code {
      font-family: var(--font-mono);
      background: var(--navy-700);
      color: var(--teal-500);
      padding: 0.15rem 0.4rem;
      border-radius: var(--r-sm);
      font-size: 0.875rem;
      border: 1px solid var(--border);
    }
    .prose blockquote {
      border-left: 3px solid var(--teal-500);
      padding: 0.75rem 1.25rem;
      background: rgba(0,212,200,0.06);
      margin: 1.25rem 0;
      border-radius: 0 var(--r-md) var(--r-md) 0;
    }
    .prose blockquote p {
      margin: 0;
      color: var(--text-primary);
      font-style: italic;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0;
      font-size: 0.9rem;
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      overflow: hidden;
    }
    .prose th {
      background: var(--navy-600);
      color: var(--text-primary);
      padding: 0.625rem 0.875rem;
      text-align: left;
      font-weight: 600;
      font-family: var(--font-sans);
      border-bottom: 1px solid var(--border);
    }
    .prose td {
      padding: 0.65rem 0.875rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-secondary);
      font-family: var(--font-serif);
    }
    .prose tr:last-child td { border-bottom: 0; }
    .prose tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
    .prose a {
      color: var(--teal-500);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .prose a:hover { color: var(--teal-400); }

    /* ══════════ Article visual panels ══════════ */

    /* Stats row */
    .prose .stat-row {
      background: linear-gradient(135deg, rgba(0,212,200,0.12) 0%, rgba(9,20,38,0.9) 100%);
      border: 1px solid rgba(0,212,200,0.25);
      border-radius: 18px;
      padding: 28px 20px;
      margin: 2rem 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      text-align: center;
    }
    .prose .stat-row > div {
      padding: 0 12px;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .prose .stat-row > div:last-child { border-right: 0; }
    .prose .stat-num {
      font-size: clamp(1.75rem, 7vw, 2.75rem);
      font-weight: 700;
      color: var(--teal-500);
      letter-spacing: -0.05em;
      line-height: 1;
      font-family: var(--font-sans);
    }
    .prose .stat-lbl {
      font-size: clamp(0.62rem, 2vw, 0.7rem);
      color: rgba(255,255,255,0.45);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-family: var(--font-mono);
      margin-top: 8px;
    }
    @media (max-width: 480px) {
      .prose .stat-row { padding: 22px 10px; }
      .prose .stat-row > div { padding: 0 6px; }
    }

    /* Simulated app screen */
    .prose .app-screen {
      background: #0A1929;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 18px 18px;
      margin: 1.75rem 0;
    }
    .prose .app-screen-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: rgba(0,212,200,0.7);
      letter-spacing: 0.1em;
      margin-bottom: 14px;
      text-transform: uppercase;
    }
    .prose .app-screen-rows { display: flex; flex-direction: column; gap: 8px; }
    .prose .app-row {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-left-width: 3px;
      border-radius: 8px;
      padding: 10px 14px;
    }
    .prose .app-row--red   { background: rgba(220,50,50,0.12);  border-color: rgba(220,50,50,0.3);  border-left-color: #DC3232; }
    .prose .app-row--amber { background: rgba(230,140,30,0.1);  border-color: rgba(230,140,30,0.25); border-left-color: #E68C1E; }
    .prose .app-row--teal  { background: rgba(0,212,200,0.07);  border-color: rgba(0,212,200,0.2);  border-left-color: #00D4C8; }
    .prose .app-row-title {
      color: #fff;
      font-size: 0.85rem;
      font-weight: 600;
      font-family: var(--font-sans);
    }
    .prose .app-row-sub {
      color: rgba(255,255,255,0.5);
      font-size: 0.72rem;
      font-family: var(--font-mono);
      margin-top: 3px;
      line-height: 1.4;
    }

    /* Feature grids (2-col labelled cards, stacks on mobile) */
    .prose .feature-grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin: 1.75rem 0;
    }
    @media (max-width: 560px) {
      .prose .feature-grid-2 { grid-template-columns: 1fr; }
    }
    .prose .feature-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 14px 16px;
    }
    .prose .feature-eyebrow {
      color: rgba(0,212,200,0.8);
      font-family: var(--font-mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
    }
    .prose .feature-body {
      color: #e2e8f0;
      font-size: 0.9rem;
      font-weight: 500;
      font-family: var(--font-sans);
      line-height: 1.55;
    }

    /* Icon feature row (3-col, stacks on mobile) */
    .prose .icon-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin: 1.75rem 0;
    }
    @media (max-width: 560px) {
      .prose .icon-grid-3 { grid-template-columns: 1fr; }
    }
    .prose .icon-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 18px 20px;
      text-align: center;
    }
    .prose .icon-card-emoji { font-size: 1.6rem; margin-bottom: 8px; }
    .prose .icon-card-title {
      color: #e2e8f0;
      font-size: 0.88rem;
      font-weight: 600;
      font-family: var(--font-sans);
      margin-bottom: 4px;
    }
    .prose .icon-card-sub {
      color: rgba(255,255,255,0.5);
      font-size: 0.78rem;
      font-family: Georgia, serif;
      line-height: 1.5;
    }

    /* Pull quote block */
    .prose .pullquote {
      background: linear-gradient(135deg, rgba(0,212,200,0.08) 0%, rgba(5,15,28,0.98) 100%);
      border-left: 3px solid rgba(0,212,200,0.6);
      border-radius: 0 14px 14px 0;
      padding: 22px 24px;
      margin: 0.5rem 0 2rem;
    }
    .prose .pullquote-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: rgba(0,212,200,0.6);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 10px;
    }
    .prose .pullquote-body {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(1rem, 3.5vw, 1.15rem);
      color: rgba(255,255,255,0.9);
      line-height: 1.65;
      font-style: italic;
    }

    /* Teal callout box */
    .prose .callout-teal {
      background: linear-gradient(135deg, rgba(0,212,200,0.1) 0%, rgba(9,20,38,0.95) 100%);
      border: 1px solid rgba(0,212,200,0.2);
      border-radius: 14px;
      padding: 22px 24px;
      margin: 1.75rem 0;
    }
    .prose .callout-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: rgba(0,212,200,0.65);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 12px;
    }
    .prose .callout-body {
      font-family: Georgia, serif;
      font-size: clamp(0.95rem, 2.5vw, 1.02rem);
      color: rgba(255,255,255,0.88);
      line-height: 1.65;
    }

    /* On-call thoughts grid */
    .prose .thoughts-grid {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 22px 24px;
      margin: 1.75rem 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px 20px;
    }
    @media (max-width: 520px) {
      .prose .thoughts-grid {
        grid-template-columns: 1fr;
        padding: 18px 20px;
        gap: 10px;
      }
    }
    .prose .thought-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      color: rgba(255,255,255,0.7);
      font-size: 0.92rem;
      font-family: Georgia, serif;
      line-height: 1.5;
    }
    .prose .thought-item::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(220,50,50,0.7);
      margin-top: 8px;
      flex-shrink: 0;
    }

    /* Letter-style opener (after "A note to..." heading) */
    .prose .letter-opener {
      font-family: var(--font-serif);
      font-style: italic;
      color: var(--text-primary);
      font-size: 1.1rem;
      line-height: 1.65;
      max-width: 34ch;
      margin: 0 0 2rem;
      letter-spacing: -0.005em;
    }

    /* Standalone emphasis line — visual anchor */
    .prose .pullout {
      font-family: var(--font-serif);
      font-size: 1.2rem;
      font-style: italic;
      color: var(--text-primary);
      line-height: 1.5;
      text-align: center;
      margin: 2.25rem auto;
      max-width: 28ch;
      letter-spacing: -0.005em;
    }

    /* Clean feature block (replaces emoji icon cards) */
    .prose .feature-block {
      margin: 2rem 0;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 1.75rem 0;
    }
    .prose .feature-item { display: block; }
    .prose .feature-label {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: -0.01em;
      margin-bottom: 0.35rem;
    }
    .prose .feature-desc {
      font-family: var(--font-serif);
      font-size: 0.98rem;
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    /* Mobile tweaks for generic prose spacing inside panels */
    @media (max-width: 560px) {
      .article-wrap { padding: 2.25rem 1.1rem 3.5rem; }
      .prose h2 { font-size: 1.3rem; margin: 2.25rem 0 1rem; }
      .prose h3 { font-size: 1.05rem; }
      .prose p { line-height: 1.75; }
      .prose .pullout { font-size: 1.08rem; margin: 1.75rem auto; }
      .prose .letter-opener { font-size: 1.02rem; }
      .prose .callout-teal,
      .prose .pullquote,
      .prose .app-screen { padding: 18px 18px; }
    }
  </style>

</Base>
