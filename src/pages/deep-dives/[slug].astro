---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('deep-dives');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---
<Base title={article.data.title} description={article.data.description} image="/og-image.png">

  <section class="u-hero" style="padding: 4.5rem 1.5rem 3.25rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <a href="/deep-dives" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1.5rem;" onmouseover="this.style.color='rgba(255,255,255,0.85)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">
        ← Deep Dives
      </a>
      <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
        {article.data.tags && article.data.tags.map((tag: string) => (
          <span style="background-color: rgba(0,212,200,0.15); color: #33DDD3; font-size: 0.72rem; padding: 0.25rem 0.65rem; border-radius: 100px; font-weight: 600; letter-spacing: 0.03em; border: 1px solid rgba(0,212,200,0.25);">{tag}</span>
        ))}
      </div>
      <h1 class="u-gradient-text" style="font-size: clamp(1.85rem, 4.5vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem; line-height: 1.2;">{article.data.title}</h1>
      <p style="color: rgba(255,255,255,0.6); font-size: 0.9rem; margin: 0;">{article.data.date} · Written by {article.data.author || 'Nity G, Urology SpR'}</p>
    </div>
  </section>

  <!-- Clinical safety banner -->
  <div class="safety-banner">
    <div class="safety-banner-inner">
      <p>⚠️ Quick reference only — not a substitute for senior clinical advice or your trust guidelines. Always escalate when in doubt.</p>
    </div>
  </div>

  <!-- Article body -->
  <article class="article-wrap">
    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .safety-banner {
      background: rgba(0,212,200,0.08);
      border-bottom: 1px solid rgba(0,212,200,0.2);
      padding: 0.75rem 1.5rem;
    }
    .safety-banner-inner { max-width: 750px; margin: 0 auto; }
    .safety-banner p {
      color: var(--teal-500);
      font-family: var(--font-mono);
      font-size: 0.78rem;
      margin: 0;
      line-height: 1.55;
      letter-spacing: 0.01em;
    }
    .article-wrap {
      padding: 3rem 1.5rem 5rem;
      max-width: 750px;
      margin: 0 auto;
    }
    .prose h2 {
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 2.25rem 0 0.875rem;
      letter-spacing: -0.02em;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
    }
    .prose h3 {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 1.5rem 0 0.625rem;
      letter-spacing: -0.015em;
    }
    .prose p {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      line-height: 1.75;
      margin: 0 0 1rem;
      font-size: 1.02rem;
    }
    .prose ul, .prose ol {
      color: var(--text-secondary);
      padding-left: 1.5rem;
      margin: 0.75rem 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .prose li {
      font-family: var(--font-serif);
      font-size: 0.98rem;
      line-height: 1.65;
    }
    .prose strong {
      color: var(--text-primary);
      font-weight: 600;
    }
    .prose code {
      font-family: var(--font-mono);
      background: var(--navy-700);
      color: var(--teal-500);
      padding: 0.15rem 0.4rem;
      border-radius: var(--r-sm);
      font-size: 0.875rem;
      border: 1px solid var(--border);
    }
    .prose blockquote {
      border-left: 3px solid var(--teal-500);
      padding: 0.75rem 1.25rem;
      background: rgba(0,212,200,0.06);
      margin: 1.25rem 0;
      border-radius: 0 var(--r-md) var(--r-md) 0;
    }
    .prose blockquote p {
      margin: 0;
      color: var(--text-primary);
      font-style: italic;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0;
      font-size: 0.9rem;
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      overflow: hidden;
    }
    .prose th {
      background: var(--navy-600);
      color: var(--text-primary);
      padding: 0.625rem 0.875rem;
      text-align: left;
      font-weight: 600;
      font-family: var(--font-sans);
      border-bottom: 1px solid var(--border);
    }
    .prose td {
      padding: 0.65rem 0.875rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-secondary);
      font-family: var(--font-serif);
    }
    .prose tr:last-child td { border-bottom: 0; }
    .prose tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
    .prose a {
      color: var(--teal-500);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .prose a:hover { color: var(--teal-400); }
  </style>

</Base>
