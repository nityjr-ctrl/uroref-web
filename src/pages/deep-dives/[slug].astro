---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('deep-dives');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---
<Base title={article.data.title} description={article.data.description} image="/og-image.png">

  <section class="u-hero" style="padding: 4.5rem 1.5rem 3.25rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <a href="/deep-dives" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1.5rem;" onmouseover="this.style.color='rgba(255,255,255,0.85)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">
        ← Deep Dives
      </a>
      <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
        {article.data.tags && article.data.tags.map((tag: string) => (
          <span style="background-color: rgba(0,212,200,0.15); color: #33DDD3; font-size: 0.72rem; padding: 0.25rem 0.65rem; border-radius: 100px; font-weight: 600; letter-spacing: 0.03em; border: 1px solid rgba(0,212,200,0.25);">{tag}</span>
        ))}
      </div>
      <h1 class="u-gradient-text" style="font-size: clamp(1.85rem, 4.5vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem; line-height: 1.2;">{article.data.title}</h1>
      {article.data.anchor && (
        <p class="article-anchor">{article.data.anchor}</p>
      )}
      <p style="color: rgba(255,255,255,0.6); font-size: 0.9rem; margin: 0 0 0.6rem;">{article.data.date} · Written by {article.data.author || 'Nity G, Urology SpR'}</p>
      <p class="article-safety-note">For reference only — not a substitute for clinical judgement.</p>
    </div>
  </section>

  <!-- Hero image -->
  {article.data.image && (
    <div class="article-hero-image">
      <img src={article.data.image} alt={article.data.title} />
    </div>
  )}

  <!-- Article body -->
  <article class="article-wrap">
    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .article-anchor {
      font-family: var(--font-serif);
      font-style: italic;
      color: rgba(255,255,255,0.72);
      font-size: 1.05rem;
      line-height: 1.55;
      max-width: 40ch;
      margin: 0.25rem 0 1.5rem;
      letter-spacing: -0.005em;
    }
    .article-safety-note {
      color: rgba(255,255,255,0.38);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.02em;
      margin: 0;
    }
    .article-wrap {
      padding: 3.5rem 1.5rem 5rem;
      max-width: 680px;
      margin: 0 auto;
    }
    .prose h2 {
      font-size: 1.45rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 4.75rem 0 1.75rem;
      letter-spacing: -0.02em;
    }
    .prose h3 {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 3rem 0 1rem;
      letter-spacing: -0.015em;
    }
    .prose p {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      font-weight: 400;
      line-height: 1.75;
      margin: 0 0 1.85rem;
      font-size: 1rem;
    }
    .prose ul, .prose ol {
      color: var(--text-secondary);
      padding-left: 1.5rem;
      margin: 0.75rem 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .prose li {
      font-family: var(--font-serif);
      font-size: 0.98rem;
      line-height: 1.65;
    }
    .prose strong {
      color: var(--text-primary);
      font-weight: 600;
    }
    .prose code {
      font-family: var(--font-mono);
      background: var(--navy-700);
      color: var(--teal-500);
      padding: 0.15rem 0.4rem;
      border-radius: var(--r-sm);
      font-size: 0.875rem;
      border: 1px solid var(--border);
    }
    .prose blockquote {
      border-left: 3px solid var(--teal-500);
      padding: 1rem 1.5rem;
      background: rgba(0,212,200,0.06);
      margin: 2.25rem 0;
      border-radius: 0 var(--r-md) var(--r-md) 0;
    }
    .prose blockquote p {
      margin: 0;
      color: var(--text-primary);
      font-style: italic;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0;
      font-size: 0.9rem;
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      overflow: hidden;
    }
    .prose th {
      background: var(--navy-600);
      color: var(--text-primary);
      padding: 0.625rem 0.875rem;
      text-align: left;
      font-weight: 600;
      font-family: var(--font-sans);
      border-bottom: 1px solid var(--border);
    }
    .prose td {
      padding: 0.65rem 0.875rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-secondary);
      font-family: var(--font-serif);
    }
    .prose tr:last-child td { border-bottom: 0; }
    .prose tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
    .prose a {
      color: var(--teal-500);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .prose a:hover { color: var(--teal-400); }

    /* ══════════ Article visual panels ══════════ */

    /* On-call thoughts — stacked line-break rhythm */
    .prose .thoughts-grid {
      margin: 2.25rem 0;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      padding-left: 1.25rem;
      border-left: 2px solid rgba(0,212,200,0.35);
    }
    .prose .thought-item {
      color: var(--text-primary);
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.02rem;
      line-height: 1.5;
    }

    /* Letter-style opener (after "A note to..." heading) */
    .prose .letter-opener {
      font-family: var(--font-serif);
      font-style: italic;
      color: var(--text-primary);
      font-size: 1.15rem;
      line-height: 1.65;
      max-width: 36ch;
      margin: 0 0 2.75rem;
      letter-spacing: -0.005em;
    }

    /* Standalone emphasis line — visual anchor */
    .prose .pullout {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-style: italic;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1.4;
      text-align: center;
      margin: 4rem auto;
      max-width: 32ch;
      letter-spacing: -0.01em;
    }

    /* Clean feature block (replaces emoji icon cards) */
    .prose .feature-block {
      margin: 2.5rem 0;
      display: flex;
      flex-direction: column;
      gap: 2.25rem;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 2.25rem 0;
    }
    .prose .feature-item { display: block; }
    .prose .feature-label {
      font-family: var(--font-sans);
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: -0.01em;
      margin-bottom: 0.4rem;
    }
    .prose .feature-desc {
      font-family: var(--font-serif);
      font-size: 0.98rem;
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    /* Grounded closing line */
    .prose .article-closing {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--text-muted);
      letter-spacing: 0.02em;
      text-align: center;
      margin: 3.5rem auto 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      max-width: 32ch;
    }

    /* Hero image */
    .article-hero-image {
      max-width: 750px;
      margin: 0 auto;
      padding: 0 1.5rem 2.5rem;
    }
    .article-hero-image img {
      width: 100%;
      display: block;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    /* Pull quote — opens every article */
    .prose .pullquote {
      margin: 0 0 2.5rem;
      padding: 1.25rem 1.5rem;
      border-left: 3px solid var(--teal-500);
      background: rgba(0,212,200,0.06);
      border-radius: 0 var(--r-md) var(--r-md) 0;
    }
    .prose .pullquote-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--teal-500);
      margin-bottom: 0.65rem;
    }
    .prose .pullquote-body {
      font-family: var(--font-serif);
      font-size: 1.08rem;
      font-style: italic;
      color: var(--text-primary);
      line-height: 1.6;
      margin: 0;
    }

    /* Teal callout — app feature highlight */
    .prose .callout-teal {
      margin: 2.25rem 0;
      padding: 1.25rem 1.5rem;
      background: rgba(0,212,200,0.08);
      border: 1px solid rgba(0,212,200,0.2);
      border-radius: var(--r-md);
    }
    .prose .callout-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--teal-500);
      margin-bottom: 0.65rem;
    }
    .prose .callout-body {
      font-family: var(--font-serif);
      font-size: 0.95rem;
      color: var(--text-secondary);
      line-height: 1.65;
      margin: 0;
    }

    /* Inline images in article body */
    .prose img {
      width: 100%;
      display: block;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.08);
      margin: 0.25rem 0;
    }
    .prose div[style*="margin: 2rem"] {
      margin: 2rem 0 !important;
    }

    /* Mobile tweaks for generic prose spacing inside panels */
    @media (max-width: 560px) {
      .article-hero-image { padding: 0 1.1rem 2rem; }
      .prose .pullquote { padding: 1rem 1.25rem; }
      .prose .pullquote-body { font-size: 1rem; }
      .prose .callout-teal { padding: 1rem 1.25rem; }
      .article-wrap { padding: 2.25rem 1.1rem 3.5rem; }
      .prose h2 { font-size: 1.3rem; margin: 3.25rem 0 1.25rem; }
      .prose h3 { font-size: 1.05rem; margin: 2.25rem 0 0.75rem; }
      .prose p { line-height: 1.7; margin: 0 0 1.5rem; }
      .prose .pullout { font-size: 1.22rem; margin: 2.75rem auto; max-width: 28ch; }
      .prose .letter-opener { font-size: 1.05rem; margin-bottom: 2rem; }
      .prose .feature-block { gap: 1.75rem; padding: 1.75rem 0; }
      .prose .article-closing { margin-top: 2.5rem; padding-top: 1.75rem; }
      .article-anchor { font-size: 0.98rem; }
    }
  </style>

</Base>
