---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('deep-dives');
---
<Base title="Deep Dives" description="In-depth urology clinical guides for registrars and trainees — written by an SpR, peer reviewed.">

  <section class="u-hero" style="padding: 5.5rem 1.5rem 4.5rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <div class="u-eyebrow-pill" style="margin-bottom: 1.5rem;">Articles</div>
      <h1 class="u-gradient-text" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem; line-height: 1.15;">Deep Dives</h1>
      <p style="color: rgba(255,255,255,0.72); font-size: 1.1rem; line-height: 1.7; margin: 0;">
        Detailed clinical guides for urology trainees. Written by an SpR, covering the topics that matter on the wards and in exams.
      </p>
    </div>
  </section>

  <section class="dives-list">
    {articles.length === 0 ? (
      <div class="dives-empty">
        <p>The first Deep Dive is coming soon.</p>
        <a href="https://forms.gle/4QTK3MSgMsedJQEw7" target="_blank" rel="noopener" class="u-cta-primary">Get it in your inbox →</a>
      </div>
    ) : (
      <div class="dives-stack">
        {articles.map(article => (
          <a href={`/deep-dives/${article.id}`} class="dive-link">
            <div class="dive-meta">
              {article.data.tags && article.data.tags.map((tag: string) => (
                <span class="dive-tag">{tag}</span>
              ))}
              <span class="dive-date">{article.data.date}</span>
            </div>
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>
    )}
  </section>

  <style>
    .dives-list {
      padding: 4rem 1.5rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .dives-empty {
      text-align: center;
      padding: 3rem 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.25rem;
    }
    .dives-empty p {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      font-size: 1.05rem;
      margin: 0;
    }
    .dives-stack {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .dive-link {
      display: block;
      background: var(--navy-700);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.75rem;
      text-decoration: none;
      transition: border-color 0.15s, transform 0.2s;
    }
    .dive-link:hover { border-color: var(--teal-500); transform: translateY(-2px); }
    .dive-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.625rem;
      flex-wrap: wrap;
    }
    .dive-tag {
      background: var(--navy-800);
      color: var(--text-secondary);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      padding: 0.2rem 0.55rem;
      border-radius: var(--r-sm);
      border: 1px solid var(--border);
      letter-spacing: 0.03em;
    }
    .dive-date {
      font-family: var(--font-mono);
      color: var(--text-muted);
      font-size: 0.78rem;
    }
    .dive-link h2 {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0 0 0.5rem;
      letter-spacing: -0.015em;
    }
    .dive-link p {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      font-size: 0.95rem;
      margin: 0;
      line-height: 1.6;
    }
  </style>

</Base>
