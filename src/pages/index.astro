---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const NEWSLETTER_URL = 'https://forms.gle/4QTK3MSgMsedJQEw7';
const APP_STORE_URL = 'https://apps.apple.com/us/app/uroref/id6761680168';
const PLAY_STORE_URL = 'https://play.google.com/store/apps/details?id=com.nityg.uroref';

function slotFromTags(tags: string[] | undefined): string {
  const primary = (tags?.[0] ?? '').toLowerCase();
  if (primary.includes('landmark')) return 'landmark';
  if (primary.includes('stone'))    return 'stones';
  if (primary.includes('frcs'))     return 'frcs';
  if (primary.includes('onc'))      return 'oncology';
  return 'oncall';
}

function readTimeFrom(body: string | undefined): string {
  if (!body) return '5 min';
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(3, Math.round(words / 200))} min`;
}

const allDives = await getCollection('deep-dives');
const live = allDives
  .slice()
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1))
  .map(a => ({
    href: `/deep-dives/${a.id}`,
    category: (a.data.tags?.[0] ?? 'Deep Dive').toString(),
    coverTitle: a.data.title,
    title: a.data.title,
    description: a.data.description,
    date: a.data.date,
    readTime: readTimeFrom(a.body),
    slot: slotFromTags(a.data.tags),
  }));

const featured = live[0];
const cards = live.slice(0, 3);
const hasLiveContent = cards.length > 0;

function catColor(slot: string): string {
  switch (slot) {
    case 'landmark': return 'var(--cat-landmark)';
    case 'oncall':   return 'var(--cat-oncall)';
    case 'frcs':     return 'var(--cat-frcs)';
    case 'stones':   return 'var(--cat-stones)';
    case 'oncology': return 'var(--cat-oncology)';
    default:         return 'var(--cat-default)';
  }
}
---
<Base title="Evidence for UK urology trainees" description="UroRef — evidence for UK urology trainees. Landmark trials, on-call pathways and FRCS-standard summaries, registrar to registrar.">

  <!-- Hero -->
  <section class="home-hero">
    <div class="home-hero-glow" aria-hidden="true"></div>

    <div class="home-hero-inner">
      <div>
        <div class="home-eyebrow">
          <span class="u-live-dot"></span>UroRef · written by an ex urology SHO
        </div>
        <h1>Everything I wish I had on my <em>first urology on-call.</em></h1>
        <p class="lead">
          A quick-reference app for real-world urology on-calls.
        </p>
        <div class="home-hero-cta">
          <a href={APP_STORE_URL} target="_blank" rel="noopener" class="store-btn" aria-label="Download UroRef on the App Store">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.07-.48-2.05-.52-3.19 0-1.43.7-2.16.5-3.03-.4C2.08 14.14 2.87 4.9 9.05 4.58c1.43.07 2.44.78 3.29.84 1.29-.25 2.53-1 3.9-.92 1.64.13 2.88.82 3.68 2.06-3.39 2.03-2.59 6.49.54 7.74-.63 1.63-1.44 3.24-2.41 5.98zM12.03 4.5c-.17-2.45 1.8-4.47 4.07-4.67.31 2.83-2.55 4.98-4.07 4.67z"/></svg>
            <span class="store-label">
              <span class="store-small">Download on the</span>
              <span class="store-big">App Store</span>
            </span>
          </a>
          <a href={PLAY_STORE_URL} target="_blank" rel="noopener" class="store-btn" aria-label="Get UroRef on Google Play">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#34A853" d="M3.25 2.073A1 1 0 0 0 3 2.734v18.532a1 1 0 0 0 .25.66L13.792 12 3.25 2.073z"/>
              <path fill="#FBBC04" d="M16.81 8.99 6.05 2.79l9.235 9.21z"/>
              <path fill="#EA4335" d="M6.05 21.21 16.81 15.01 15.285 12z"/>
              <path fill="#4285F4" d="m20.16 10.81-3.35-1.82L13.792 12l3.018 3.01 3.35-1.82a1.36 1.36 0 0 0 0-2.38z"/>
            </svg>
            <span class="store-label">
              <span class="store-small">Get it on</span>
              <span class="store-big">Google Play</span>
            </span>
          </a>
        </div>
      </div>

      <!-- Featured article card -->
      {featured ? (
        <a href={featured.href} class="featured-card" aria-label={`Read: ${featured.title}`}>
          <div class="cover" style={`--cat: ${catColor(featured.slot)};`}>
            <div class="cover-number">{featured.category.toUpperCase()}</div>
            <div class="cover-title">{featured.title}</div>
            <div class="cover-graphic">
              <span>{featured.date}</span>
              <span>{featured.readTime}</span>
            </div>
          </div>
          <div class="body">
            <div class="cat"><span class="bullet"></span>Latest deep dive</div>
            <h3>{featured.title}</h3>
            <p>{featured.description}</p>
            <div class="foot">
              <span>{featured.date} · {featured.readTime}</span>
              <span class="read">READ →</span>
            </div>
          </div>
        </a>
      ) : (
        <a href={NEWSLETTER_URL} target="_blank" rel="noopener" class="featured-card featured-card-empty" aria-label="Join the newsletter for the first issue">
          <div class="cover">
            <div class="cover-number">ISSUE 01</div>
            <div class="cover-title">First issue<br/>launching soon.</div>
            <div class="cover-graphic">
              <span>Sign up for the launch</span>
            </div>
          </div>
          <div class="body">
            <div class="cat"><span class="bullet"></span>Upcoming</div>
            <h3>Be the first to read it.</h3>
            <p>The first Deep Dive lands shortly. Join the newsletter and it'll arrive in your inbox the morning it publishes.</p>
            <div class="foot">
              <span>Launching soon</span>
              <span class="read">JOIN →</span>
            </div>
          </div>
        </a>
      )}
    </div>
  </section>

  <!-- [2] Key value section -->
  <section class="value-band">
    <div class="value-inner">
      <div class="value-col">
        <span class="value-mark">01</span>
        <h3>Designed for real on-calls</h3>
        <p>Built around common scenarios faced by trainees.</p>
      </div>
      <div class="value-col">
        <span class="value-mark">02</span>
        <h3>Fast and practical</h3>
        <p>Focused on quick access rather than long guidelines.</p>
      </div>
      <div class="value-col">
        <span class="value-mark">03</span>
        <h3>Structured and accessible</h3>
        <p>Information organised for clarity under pressure.</p>
      </div>
    </div>
  </section>

  <!-- [3] Screenshots / app visual -->
  <section class="app-band">
    <div class="app-band-inner">
      <div>
        <h2>The same content, in your <em>pocket</em>.</h2>
        <p>UroRef the app is the on-call companion to this publication. 16 procedures, emergency decision trees, drug doses, calculators, clinic frameworks and 31 BAUS leaflets. Used by 500+ trainees across the UK. Works offline, because wards do not.</p>
        <div class="app-badges">
          <a href={APP_STORE_URL} target="_blank" rel="noopener" class="badge" aria-label="Download UroRef on the App Store">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.07-.48-2.05-.52-3.19 0-1.43.7-2.16.5-3.03-.4C2.08 14.14 2.87 4.9 9.05 4.58c1.43.07 2.44.78 3.29.84 1.29-.25 2.53-1 3.9-.92 1.64.13 2.88.82 3.68 2.06-3.39 2.03-2.59 6.49.54 7.74-.63 1.63-1.44 3.24-2.41 5.98zM12.03 4.5c-.17-2.45 1.8-4.47 4.07-4.67.31 2.83-2.55 4.98-4.07 4.67z"/></svg>
            <div class="label"><span class="small">Download on the</span><span class="big">App Store</span></div>
          </a>
          <a href={PLAY_STORE_URL} target="_blank" rel="noopener" class="badge" aria-label="Get UroRef on Google Play">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#34A853" d="M3.25 2.073A1 1 0 0 0 3 2.734v18.532a1 1 0 0 0 .25.66L13.792 12 3.25 2.073z"/>
              <path fill="#FBBC04" d="M16.81 8.99 6.05 2.79l9.235 9.21z"/>
              <path fill="#EA4335" d="M6.05 21.21 16.81 15.01 15.285 12z"/>
              <path fill="#4285F4" d="m20.16 10.81-3.35-1.82L13.792 12l3.018 3.01 3.35-1.82a1.36 1.36 0 0 0 0-2.38z"/>
            </svg>
            <div class="label"><span class="small">Get it on</span><span class="big">Google Play</span></div>
          </a>
        </div>
      </div>

      <div class="app-visual">
        <div class="app-phone">
          <div class="app-phone-screen">
            <div class="app-phone-eyebrow">ON-CALL · 02:47</div>
            <div class="app-phone-row red"><b>Obstructed infected kidney</b>Resus → decompress within hrs</div>
            <div class="app-phone-row red"><b>Priapism</b>Ischaemic vs non-ischaemic</div>
            <div class="app-phone-row amber"><b>Clot retention</b>3-way · CBI · theatre if fails</div>
            <div class="app-phone-row accent"><b>BOOI / BCI</b>UDS calculator</div>
            <div class="app-phone-row"><b>JJ stent insertion</b>Op note</div>
            <div class="app-phone-row"><b>Difficult catheterisation</b>Tree</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- [4] Stats / credibility section -->
  <section class="stats-band">
    <div class="stats-inner">
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-num">500+</div>
          <div class="stat-lbl">Trainees</div>
        </div>
        <div class="stat">
          <div class="stat-num">16</div>
          <div class="stat-lbl">Pathways</div>
        </div>
        <div class="stat">
          <div class="stat-num">31</div>
          <div class="stat-lbl">Patient leaflets</div>
        </div>
      </div>
      <p class="stats-note">Used by trainees across the UK</p>
    </div>
  </section>

  <!-- [5] Quote / why section -->
  <section class="quote-band">
    <div class="quote-inner">
      <blockquote class="quote">
        <p>&ldquo;Sometimes someone suddenly asks you, &lsquo;What&rsquo;s monopolar versus bipolar?&rsquo; and your brain freezes.</p>
        <p>The answer is simple &mdash; but in the moment, even simple knowledge can feel briefly out of reach.&rdquo;</p>
      </blockquote>
      <p class="quote-support">UroRef was built during training to make those moments easier, by organising commonly used information into a more accessible format.</p>
    </div>
  </section>

  <!-- [6] Deep dives -->
  {hasLiveContent && (
    <section class="latest">
      <div class="latest-inner">
        <div class="latest-head">
          <h2>Latest <em>deep dives</em></h2>
          <a class="all" href="/deep-dives">All posts →</a>
        </div>

        <div class="post-grid">
          {cards.map(card => (
            <a href={card.href} class={`post-card post-card-${card.slot}`}>
              <div class="cover" style={`--cat: ${catColor(card.slot)};`}>
                <div class="cover-label">
                  <em>{card.category}</em>
                  {card.coverTitle}
                </div>
              </div>
              <div class="body">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
                <div class="foot">
                  <span>{card.date}</span>
                  <span>{card.readTime}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>

<style>
  /* ══════════ HERO ══════════ */
  .home-hero {
    position: relative;
    padding: 88px 32px 80px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .home-hero-glow {
    position: absolute;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(0,212,200,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .home-hero-inner {
    max-width: var(--container);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 56px;
    align-items: center;
    position: relative;
  }

  .home-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--teal-500);
    font-weight: 500;
    margin-bottom: 20px;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .home-hero h1 {
    font-family: var(--font-sans);
    font-size: clamp(42px, 6vw, 72px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0 0 24px 0;
    text-wrap: balance;
  }
  .home-hero h1 em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    color: var(--teal-500);
    letter-spacing: -0.015em;
  }
  .home-hero .lead {
    font-family: var(--font-serif);
    font-size: 21px;
    font-weight: 400;
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 56ch;
    margin: 0 0 36px 0;
    letter-spacing: -0.005em;
  }
  .home-hero-cta { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }

  /* Platform download buttons — dominant hero CTA */
  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--navy-900);
    color: var(--text-primary);
    padding: 12px 20px;
    border-radius: var(--r-lg);
    border: 1px solid var(--border-strong);
    text-decoration: none;
    min-width: 200px;
    transition: border-color 0.15s, transform 0.15s, background 0.15s;
  }
  .store-btn:hover {
    border-color: var(--teal-500);
    transform: translateY(-1px);
    background: #000;
  }
  .store-btn svg { width: 26px; height: 26px; flex-shrink: 0; }
  .store-label { display: flex; flex-direction: column; line-height: 1.15; }
  .store-small {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }
  .store-big {
    font-family: var(--font-sans);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }
  @media (max-width: 540px) {
    .home-hero-cta { flex-direction: column; align-items: stretch; gap: 10px; }
    .store-btn { width: 100%; min-width: 0; justify-content: center; }
  }

  /* Featured card */
  .featured-card {
    display: block;
    background: var(--navy-700);
    border: 1px solid var(--border);
    border-radius: var(--r-2xl);
    overflow: hidden;
    position: relative;
    z-index: 2;
    transition: border-color 0.15s, transform 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .featured-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .featured-card .cover {
    height: 260px;
    background:
      radial-gradient(circle at 30% 30%, rgba(0,212,200,0.4) 0%, transparent 50%),
      linear-gradient(135deg, #0F2E4F 0%, #050F1C 100%);
    position: relative;
    overflow: hidden;
  }
  .featured-card .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(90deg, transparent 0 40px, rgba(255,255,255,0.02) 40px 41px),
      repeating-linear-gradient(0deg, transparent 0 40px, rgba(255,255,255,0.02) 40px 41px);
  }
  .featured-card .cover-graphic {
    position: absolute;
    bottom: 20px; left: 20px; right: 20px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
  }
  .featured-card .cover-number {
    position: absolute;
    top: 24px; right: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--teal-500);
    border: 1px solid var(--teal-500);
    padding: 4px 8px;
    border-radius: var(--r-sm);
    letter-spacing: 0.04em;
  }
  .featured-card .cover-title {
    position: absolute;
    top: 76px; left: 28px; right: 28px;
    font-family: var(--font-sans);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--text-primary);
    text-wrap: balance;
  }
  .featured-card .cover-title span { color: var(--teal-500); }
  .featured-card .body { padding: 24px 28px 28px; }
  .featured-card .cat {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cat-landmark);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .featured-card .cat .bullet {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cat-landmark);
  }
  .featured-card h3 {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 10px 0;
  }
  .featured-card p {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0 0 16px 0;
  }
  .featured-card .foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  .featured-card .foot .read {
    color: var(--teal-500);
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .home-hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .home-hero { padding: 56px 20px 48px; }
  }

  /* ══════════ LATEST POSTS ══════════ */
  .latest {
    padding: 88px 32px 40px;
    border-bottom: 1px solid var(--border);
  }
  .latest-inner { max-width: var(--container); margin: 0 auto; }
  .latest-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .latest-head h2 {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0;
  }
  .latest-head h2 em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--text-muted);
    font-weight: 400;
  }
  .latest-head .all {
    font-size: 13px;
    color: var(--teal-500);
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 960px) { .post-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .post-grid { grid-template-columns: 1fr; } }

  .post-card {
    background: var(--navy-700);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s, transform 0.2s;
    cursor: pointer;
    color: inherit;
    text-decoration: none;
  }
  .post-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .post-card .cover {
    height: 180px;
    position: relative;
    overflow: hidden;
  }
  .post-card-oncall .cover   { background: linear-gradient(135deg, #3D1E1E 0%, #0A2540 80%); }
  .post-card-frcs .cover     { background: linear-gradient(135deg, #2E2240 0%, #0A2540 80%); }
  .post-card-stones .cover   { background: linear-gradient(135deg, #0F3D39 0%, #0A2540 80%); }
  .post-card-landmark .cover { background: linear-gradient(135deg, #3D3820 0%, #0A2540 80%); }
  .post-card-oncology .cover { background: linear-gradient(135deg, #3D2A0D 0%, #0A2540 80%); }
  .post-card .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, transparent 0 30px, rgba(255,255,255,0.03) 30px 31px);
  }
  .post-card .cover-label {
    position: absolute;
    bottom: 14px; left: 16px; right: 16px;
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--text-primary);
    text-wrap: balance;
  }
  .post-card .cover-label em {
    color: var(--cat, var(--cat-default));
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .post-card .body { padding: 20px 20px 22px; flex: 1; display: flex; flex-direction: column; }
  .post-card h3 {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin: 0 0 10px 0;
    text-wrap: balance;
  }
  .post-card p {
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0 0 16px 0;
    flex: 1;
  }
  .post-card .foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  /* ══════════ APP BAND ══════════ */
  .app-band {
    padding: 88px 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-top: 88px;
  }
  .app-band-inner {
    max-width: var(--container);
    margin: 0 auto;
