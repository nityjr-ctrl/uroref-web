---
import Base from '../layouts/Base.astro';

const changelog = [
  {
    version: 'v2.3',
    phase: null,
    date: 'April 2026',
    status: 'latest',
    title: 'Home screen redesign + context modes',
    items: [
      'Home screen redesign',
      'Context modes for Ward Round, On-Call, and Clinic',
      'Daily Pearl with rotating clinical tips',
      'Your Shortcuts — personalised home screen based on what you use',
      'On-Call Hub unifying decision trees and emergency protocols',
      'UI overhaul throughout',
    ],
  },
  {
    version: 'v2.3',
    phase: 'Phase 2',
    date: 'April 2026',
    status: 'latest',
    title: 'Search, pinned & recently used',
    items: [
      'Search across all content types — procedures, emergencies, drugs, antibiotics, calculators, classifications',
      'Pinned tools and recently used, persisted across sessions',
      'Match highlighting in search results',
    ],
  },
  {
    version: 'v2.3',
    phase: 'Phase 1',
    date: 'April 2026',
    status: 'latest',
    title: 'Trust layer + governance view',
    items: [
      'Trust layer',
      'Governance view',
      'Consultant review metadata on all procedures and emergencies',
      'Compact trust card on home screen replacing old disclaimer',
    ],
  },
  {
    version: 'v2.2',
    phase: null,
    date: 'Early 2026',
    status: 'previous',
    title: 'iOS release',
    items: [
      'iOS release',
      'BAUS QR codes (31 patient leaflets)',
      'Op notes library (16 templates)',
      'ED content update',
      'Leibovich Score calculator',
    ],
  },
  {
    version: 'v2.1',
    phase: null,
    date: 'Initial release',
    status: 'initial',
    title: 'Core app',
    items: [
      'Procedures',
      'Emergencies',
      'Drug doses',
      'Calculators',
      'Clinic presentations',
      'TNM staging',
    ],
  },
];
---
<Base title="Updates — UroRef Changelog" description="UroRef app changelog — version history, new features and upcoming changes.">

  <section class="u-hero" style="padding: 5.5rem 1.5rem 4.5rem;">
    <div class="u-hero-bg" aria-hidden="true"></div>
    <div class="u-hero-grid" aria-hidden="true"></div>
    <div style="max-width: 750px; margin: 0 auto; position: relative;">
      <div class="u-eyebrow-pill" style="margin-bottom: 1.5rem;">Changelog</div>
      <h1 class="u-gradient-text" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; letter-spacing: -0.03em; margin: 0 0 1rem; line-height: 1.15;">Updates</h1>
      <p style="color: rgba(255,255,255,0.72); font-size: 1.1rem; line-height: 1.7; margin: 0;">
        What's new in UroRef — features, fixes, and what's coming next.
      </p>
    </div>
  </section>

  <section class="changelog">
    <div class="changelog-stack">

      {changelog.map((entry, idx) => (
        <div class="entry">

          <!-- Timeline line + dot -->
          <div class="rail">
            <div class={`dot ${entry.status === 'latest' ? 'dot-live' : ''}`}></div>
            {idx < changelog.length - 1 && <div class="line"></div>}
          </div>

          <!-- Content -->
          <div class="content">
            <div class="entry-meta">
              <span class="version">{entry.version}{entry.phase ? ` ${entry.phase}` : ''}</span>
              {entry.status === 'latest' && <span class="badge-latest">Latest</span>}
              <span class="date">{entry.date}</span>
            </div>
            <h2>{entry.title}</h2>
            <ul>
              {entry.items.map(item => (
                <li><span class="bullet"></span><span>{item}</span></li>
              ))}
            </ul>
          </div>
        </div>
      ))}

    </div>
  </section>

  <style>
    .changelog { padding: 4rem 1.5rem; max-width: 750px; margin: 0 auto; }
    .changelog-stack { display: flex; flex-direction: column; gap: 0; position: relative; }
    .entry { display: flex; gap: 1.5rem; padding-bottom: 2.5rem; }
    .rail {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
      width: 24px;
    }
    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      margin-top: 0.35rem;
      flex-shrink: 0;
      background: var(--navy-500);
    }
    .dot-live {
      background: var(--teal-500);
      box-shadow: 0 0 0 3px rgba(0,212,200,0.2);
    }
    .line {
      width: 1px;
      background: var(--border);
      flex: 1;
      margin-top: 4px;
    }
    .content { flex: 1; padding-bottom: 0.25rem; }
    .entry-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
      flex-wrap: wrap;
    }
    .version {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text-primary);
      background: var(--navy-700);
      border: 1px solid var(--border);
      padding: 0.2rem 0.6rem;
      border-radius: var(--r-sm);
    }
    .badge-latest {
      background: rgba(0,212,200,0.15);
      color: var(--teal-500);
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.2rem 0.6rem;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border: 1px solid rgba(0,212,200,0.3);
    }
    .date { color: var(--text-muted); font-family: var(--font-mono); font-size: 0.78rem; }
    .content h2 {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0 0 0.875rem;
      letter-spacing: -0.015em;
    }
    .content ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .content li {
      display: flex;
      gap: 0.625rem;
      align-items: flex-start;
    }
    .content li .bullet {
      margin-top: 0.55rem;
      width: 4px;
      height: 4px;
      background: var(--text-muted);
      border-radius: 50%;
      flex-shrink: 0;
    }
    .content li span:last-child {
      font-family: var(--font-serif);
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.65;
    }
  </style>

</Base>
